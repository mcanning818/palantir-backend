# Palantir Intelligence Brief — Backend Environment
# Copy this file to `.env` and fill in your real keys. NEVER commit `.env`.

# ─── Required (keyed APIs) ─────────────────────
NEWSAPI_KEY=your_newsapi_key_here
SAMGOV_KEY=your_samgov_key_here

# ─── CORS — comma-separated list of allowed frontend origins ──
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://YOUR-PALANTIR-FRONTEND.netlify.app

# ─── Optional ──────────────────────────────────
# PORT defaults to 3000 (Render overrides this automatically)
# PORT=3000
